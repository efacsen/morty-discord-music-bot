# Discord Bot Configuration
# Fastest option: use the interactive onboarding instead of editing by hand.
#   macOS/Linux: ./onboard.sh
#   Windows:     .\onboard.bat
#
# Most users only need these first 2 values.
# Get them from https://discord.com/developers/applications
DISCORD_CLIENT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Guild ID (Optional, but recommended)
# Adding this makes slash commands appear instantly in your server.
# Without it, commands register globally and can take up to 1 hour to appear.
# To get Guild ID: Enable Developer Mode in Discord, right-click your server, Copy ID.
DISCORD_GUILD_ID=your_guild_id_here

# YouTube Cookies (Optional)
# The bot works without cookies for most public videos.
# Only add these if some videos fail, are age-restricted, or return HTTP 403.
# WARNING: stale cookies from a logged-in account can trigger stricter bot-detection.
# If playback breaks after adding cookies, remove the cookie setting first and retest.
#
# Option A — cookies file (recommended for Docker)
# Native (running directly with Node):
# YTDLP_COOKIES_FILE=./cookies.txt
#
# Docker (running via docker compose):
# Place cookies.txt inside the cookies/ directory, then set:
# YTDLP_COOKIES_FILE=/cookies/cookies.txt
#
# Option B — read cookies from your browser session (mainly for local/non-Docker use)
# YTDLP_COOKIES_BROWSER=chrome

# Docker Image
# Set this to the GHCR image you want Docker Compose to pull.
# Format: owner/discord-music-bot  (do not include the ghcr.io/ prefix)
# Example: IMAGE_NAME=myusername/discord-music-bot
# IMAGE_NAME=yourorg/discord-music-bot
