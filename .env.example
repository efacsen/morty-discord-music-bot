# Discord Bot Configuration
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Guild ID (Optional - recommended for development)
# Adding this makes slash commands appear instantly in your test server
# Without it, commands register globally (takes up to 1 hour)
# To get Guild ID: Enable Developer Mode in Discord, right-click your server, Copy ID
DISCORD_GUILD_ID=your_guild_id_here

# YouTube Cookies (Optional)
# The bot uses yt-dlp which handles most YouTube videos without authentication.
# Only needed for age-restricted or private videos.
# To use: export cookies from your browser using a browser extension (e.g. "Get cookies.txt LOCALLY").
# WARNING: stale cookies from a logged-in account can trigger stricter bot-detection (HTTP 403).
# If playback breaks after adding cookies, try removing them first.
#
# Native (running directly with Node):
#   Save cookies.txt next to your .env, then set:
# YTDLP_COOKIES_FILE=./cookies.txt
#
# Docker (running via docker compose):
#   Place cookies.txt inside the cookies/ directory, then set:
# YTDLP_COOKIES_FILE=/cookies/cookies.txt

# Docker Image (Optional)
# Set this to your GHCR image reference when self-hosting with a custom image.
# Format: owner/discord-music-bot  (the ghcr.io/ prefix is added automatically)
# Example: IMAGE_NAME=myusername/discord-music-bot
# IMAGE_NAME=yourorg/discord-music-bot
